# ============================================================================
#  Proxy configuration template.
#  setup.sh copies this to config/proxy.env on first run. Edit config/proxy.env
#  (NOT this file) and re-run ./sh/start.sh or ./sh/tablet.sh.
#  config/proxy.env is gitignored: your local settings never reach the repo.
# ============================================================================

PORT=8090

# ----------------------------------------------------------------------------
#  BIND: network interface the proxy listens on.
#    127.0.0.1  -> localhost only (default, safe: not reachable from the LAN).
#    0.0.0.0    -> ALL interfaces (exposes the proxy to the whole network).
#
#  SECURITY WARNING: only set 0.0.0.0 if you deliberately want LAN exposure.
#  With CORS enabled, a LAN-exposed proxy can forward requests to your local
#  backends from any machine on the network. Keep 127.0.0.1 unless you need it.
# ----------------------------------------------------------------------------
BIND=127.0.0.1

HOST_SPOOF=localhost
CORS=on

# ----------------------------------------------------------------------------
#  CORS_ORIGIN: controls Access-Control-Allow-Origin / -Allow-Credentials.
#    (empty)          -> reflect the caller Origin, credentials OFF (default,
#                        safe). Never pairs a reflected Origin with credentials.
#    *                -> allow any origin, credentials OFF.
#    https://host     -> allow ONLY this origin, credentials ON. Use a single
#                        explicit origin when you need credentialed requests.
#
#  Reflecting the Origin together with credentials would make this an open
#  credentialed relay (any site could read authenticated backend responses).
#  See MDN "Cross-Origin Resource Sharing (CORS)".
# ----------------------------------------------------------------------------
CORS_ORIGIN=

# ----------------------------------------------------------------------------
#  DEFAULT_TARGET: fallback backend used ONLY when no ROUTE lines are defined.
# ----------------------------------------------------------------------------
DEFAULT_TARGET=127.0.0.1:80

# ----------------------------------------------------------------------------
#  BUNDLE REWRITE (optional, app-specific): patches a marker inside a minified
#  JS bundle on the fly. Disabled by default. It runs only when BOTH
#  BUNDLE_REWRITE_FROM and BUNDLE_REWRITE_TO are set; leave them empty for a
#  clean pass-through proxy.
#
#    BUNDLE_MATCH        -> regex selecting which response URLs to scan.
#    BUNDLE_REWRITE_FROM -> exact substring to find in the bundle.
#    BUNDLE_REWRITE_TO   -> replacement substring.
# ----------------------------------------------------------------------------
BUNDLE_MATCH=^/App/assets/.*\.js(\?|$)
# set to your bundle's host marker to enable rewriting
BUNDLE_REWRITE_FROM=
# set to the replacement string to enable rewriting
BUNDLE_REWRITE_TO=

# ----------------------------------------------------------------------------
#  ROUTES TO EXPOSE:   ROUTE <prefix> <host:port>   (longest prefix wins)
# ----------------------------------------------------------------------------

# ROUTE /api 127.0.0.1:3000
ROUTE / 127.0.0.1:80
